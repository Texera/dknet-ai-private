        "code": "import re\nimport pandas as pd\n\ndef process(movies) -> pd.DataFrame:\n    # Extract year from title (format: \"Title (Year)\")\n    year_extracted = movies['title'].str.extract(r'\\((\\d{4})\\)')[0]\n    # Convert to int, handling NaN values by filling with 0 or filtering\n    movies['release_year'] = pd.to_numeric(year_extracted, errors='coerce').fillna(0).astype(int)\n    return movies[['movieId', 'title', 'release_year']]\n",
